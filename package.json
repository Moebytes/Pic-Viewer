{
  "name": "pic-display",
  "version": "1.0.3",
  "author": "Moebytes",
  "description": "A cute image viewer!",
  "main": "dist/main/index.js",
  "scripts": {
    "start": "npm run clean && rsbuild build && electron dist/main/index.js",
    "build": "npm run clean ./build && rsbuild build && electron-builder -p never",
    "clean": "del-cli ./dist"
  },
  "keywords": [
    "photo",
    "viewer",
    "image",
    "photoshop",
    "anime",
    "cute"
  ],
  "repository": "https://github.com/Moebytes/Pic-Display",
  "privacyPolicy": "https://moebytes.com/privacy-policy",
  "license": "CC BY-NC 4.0",
  "build": {
    "appId": "com.moebytes.pic-display",
    "productName": "Pic Display",
    "directories": {
      "buildResources": "assets",
      "output": "build"
    },
    "asar": true,
    "asarUnpack": [
      "**/node_modules/sharp/**/*",
      "**/node_modules/@img/**/*"
    ],
    "mac": {
      "icon": "assets/mas/icon.icns",
      "target": {
        "target": "mas",
        "arch": "arm64"
      },
      "type": "distribution",
      "provisioningProfile": "assets/mas/MacAppStore.provisionprofile",
      "category": "public.app-category.graphics-design"
    },
    "mas": {
      "entitlements": "assets/mas/entitlements.mas.plist",
      "entitlementsInherit": "assets/mas/entitlements.mas.inherit.plist"
    },
    "dmg": {
      "title": "${productName}",
      "background": "./assets/background.png",
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "win": {
      "icon": "assets/appx/icon.ico",
      "target": {
        "target": "appx",
        "arch": "x64"
      }
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "uninstallDisplayName": "Pic Display",
      "createDesktopShortcut": "always",
      "installerSidebar": "./assets/installer.bmp",
      "uninstallerSidebar": "./assets/installer.bmp"
    },
    "appx": {
      "identityName": "Moebytes.PicDisplay",
      "publisher": "CN=4C1B763B-CF01-4978-8749-986F562173D8",
      "publisherDisplayName": "Moebytes",
      "capabilities": [
          "runFullTrust", 
          "internetClient"
      ]
    },
    "linux": {
      "icon": "assets/icon.png",
      "target": {
        "target": "appImage",
        "arch": "x64"
      },
      "category": "Graphics"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "fileAssociations": [
      {
        "ext": "jpg",
        "description": "JPG File"
      },
      {
        "ext": "jpeg",
        "description": "JPEG File"
      },
      {
        "ext": "png",
        "description": "PNG File"
      },
      {
        "ext": "webp",
        "description": "WEBP File"
      },
      {
        "ext": "avif",
        "description": "AVIF File"
      },
      {
        "ext": "tiff",
        "description": "TIFF File"
      },
      {
        "ext": "gif",
        "description": "GIF File"
      }
    ]
  },
  "devDependencies": {
    "@electron-rsbuild/plugin-main": "^0.0.12",
    "@electron-rsbuild/plugin-preload": "^0.0.12",
    "@electron-rsbuild/plugin-renderer": "^0.0.12",
    "@rsbuild/core": "^1.7.3",
    "@rsbuild/plugin-less": "^1.6.0",
    "@rsbuild/plugin-node-polyfill": "^1.4.4",
    "@rsbuild/plugin-react": "^1.4.5",
    "@rsbuild/plugin-type-check": "^1.3.3",
    "@svgr/webpack": "^8.1.0",
    "@types/electron-localshortcut": "^3.1.3",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/get-pixels": "^3.3.4",
    "@types/gif-encoder": "^0.7.4",
    "@types/jquery": "^3.5.33",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/request": "^2.48.13",
    "@types/sharp": "^0.32.0",
    "@types/unzipper": "^0.10.11",
    "cross-env": "^10.1.0",
    "del-cli": "^7.0.0",
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.11.2",
    "axios": "^1.13.5",
    "bootstrap": "^5.3.8",
    "catenary-curve": "^1.0.1",
    "electron-click-drag-plugin": "^2.0.2",
    "electron-localshortcut": "^3.2.1",
    "electron-store": "^8.0.0",
    "gif-encoder": "^0.7.2",
    "gif-frames": "github:Moestash/gif-frames#no-cumulative",
    "image-pixels": "^2.2.2",
    "jquery": "^4.0.0",
    "lazy-brush": "^2.0.2",
    "pixiv.ts": "^0.8.8",
    "rc-slider": "^11.1.9",
    "react": "^19.2.4",
    "react-bootstrap": "^2.10.10",
    "react-dom": "^19.2.4",
    "react-image-crop": "github:Moestash/react-image-crop",
    "react-redux": "^9.2.0",
    "react-zoom-pan-pinch": "^3.7.0",
    "resize-observer-polyfill": "^1.5.1",
    "sharp": "^0.34.5",
    "unzipper": "^0.12.3"
  }
}
